# LLM 설정 — 기본은 LM Studio (http://localhost:1234), gemma4:e4b
# Ollama로 바꾸려면 LLM_BASE_URL=http://localhost:11434/v1 로 덮어쓰면 됩니다.
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=google/gemma-4-e4b
LLM_API_KEY=lm-studio
# 비전 모델 — 미설정 시 LLM_MODEL 과 동일한 모델로 OCR 수행
# LLM_VISION_MODEL=gemma4:e4b

# OCR (기본 활성화) — 위 LLM 비전 모델로 이미지 내 중국어를 추출해
# CN/KO 캡션을 자동 삽입합니다. 배터리 이슈 등으로 끌 때만 false.
OCR_ENABLED=true
OCR_BACKEND=llm
OCR_MCP_URL=http://localhost:9000/mcp

# GitHub (단일 레포)
GITHUB_REPO_URL=https://YOUR_PAT@github.com/aisitei/aisitei.github.io.git
GIT_USER_NAME=aisitei
GIT_USER_EMAIL=your@email.com
GIT_BRANCH=main

# 스케줄 (KST 기준)
SCHEDULE_TIME=08:00
LOG_LEVEL=INFO
