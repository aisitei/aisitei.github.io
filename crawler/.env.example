# LLM 설정
LLM_PROVIDER=hybrid
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MODEL_DEEP=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b
HYBRID_CLAUDE_FOR_CAMERA=true

# OCR (기본 활성화) — Ollama 비전 모델(OLLAMA_MODEL)로 이미지 내 중국어를
# 추출해 CN/KO 캡션을 자동 삽입합니다. 배터리 이슈 등으로 끌 때만 false.
OCR_ENABLED=true
OCR_BACKEND=ollama
OCR_MCP_URL=http://localhost:9000/mcp

# GitHub (단일 레포)
GITHUB_REPO_URL=https://YOUR_PAT@github.com/aisitei/aisitei.github.io.git
GIT_USER_NAME=aisitei
GIT_USER_EMAIL=your@email.com
GIT_BRANCH=main

# 스케줄 (KST 기준)
SCHEDULE_TIME=08:00
LOG_LEVEL=INFO
